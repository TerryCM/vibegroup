{
  "mcpServers": {
    "vibegroup": {
      "command": "bun",
      "args": ["run", "src/mcpServer.ts"],
      "env": {
        "VIBEGROUP_RELAY_URL": "${VIBEGROUP_RELAY_URL}",
        "VIBEGROUP_ROOM": "${VIBEGROUP_ROOM}",
        "VIBEGROUP_TOKEN": "${VIBEGROUP_TOKEN}",
        "VIBEGROUP_NAME": "${VIBEGROUP_NAME}",
        "VIBEGROUP_MODEL": "${VIBEGROUP_MODEL}"
      }
    }
  }
}
